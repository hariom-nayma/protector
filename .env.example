BOT_TOKEN=your_token_here
HEADLESS=true
ADMIN_ID=your_telegram_id_here

# Proxy Settings (Optional - Required for Server)
# Set USE_PROXY=false to globally disable proxies for all bot tasks
USE_PROXY=true
PROXIES_FILE=proxies.txt
WEBSHARE_API_KEY=your_webshare_api_key_here
# PROXY_LIST is a comma-separated list of proxies (http://user:pass@host:port)
PROXY_LIST=http://user:pass@host:port,http://user:pass@host2:port2
PROXY_URL=http://your_proxy_ip:port
PROXY_USERNAME=your_username
PROXY_PASSWORD=your_password
